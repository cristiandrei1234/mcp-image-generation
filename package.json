{
  "name": "image-generation",
  "version": "0.1.0",
  "description": "MCP server for Google Gemini Nano Banana 2 image generation, with Claude Code skills",
  "type": "module",
  "bin": {
    "image-generation": "dist/server.js",
    "image-generation-init": "dist/init.js",
    "image-generation-install-skills": "dist/install-skills.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "prepare": "tsc -p tsconfig.build.json",
    "prepublishOnly": "npm run build",
    "dev:init": "npm run build && node dist/init.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mcp",
    "claude-code",
    "gemini",
    "nano-banana",
    "image-generation",
    "google"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "@google/genai": "^2.3.0",
    "@inquirer/prompts": "^8.4.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/node": "^25.8.0",
    "chalk": "^5.6.2",
    "mime": "^4.1.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.6",
    "vitest": "^4.1.6"
  }
}
